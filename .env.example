# OpenBoard environment variables (all optional)
# Copy to .env for local development. OpenBoard also works with zero env vars —
# provider keys/tokens are normally entered interactively and stored encrypted
# in ~/.openboard/config.json.

# Secret used to encrypt the local config (provider keys, GitHub/Vercel tokens,
# dashboard credentials). If unset, OpenBoard derives a per-machine secret.
# Set this to a stable value to move config between machines.
OPENBOARD_ENCRYPTION_SECRET=

# Override the config directory (default: ~/.openboard).
OPENBOARD_CONFIG_DIR=

# Enable verbose debug logging.
OPENBOARD_DEBUG=

# --- Generated dashboard app (set automatically during deploy; listed for reference) ---
# DASHBOARD_USERNAME=
# DASHBOARD_PASSWORD_HASH=
# JWT_SECRET=

# --- Only needed to run the token-backed end-to-end flow test ---
# scripts/test-openboard-flows.ps1 -UseRealTokens
# OPENBOARD_TEST_GITHUB_TOKEN=
# OPENBOARD_TEST_VERCEL_TOKEN=
